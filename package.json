{
  "name": "1click-temp-mail-autofill",
  "version": "2.0.0",
  "description": "Generate temporary email addresses and auto-fill OTPs and login forms with one click.",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt --browser firefox",
    "build": "wxt build",
    "build:firefox": "wxt build --browser firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip --browser firefox",
    "prepare": "wxt prepare",
    "clean": "wxt clean",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.40",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.2",
    "wxt": "^0.21.0"
  },
  "keywords": [
    "chrome-extension",
    "firefox-addon",
    "temp-mail",
    "autofill",
    "otp",
    "email"
  ],
  "author": "UnarchiveTech",
  "license": "MIT",
  "dependencies": {
    "jszip": "^3.10.1"
  }
}
