    "operations": {
      "createInbox": {
        "method": "GET",
        "function": "get_email_address",
        "requiredParams": {
          "ip": "127.0.0.1",
          "agent": "1ClickExt"
        },
        "optionalParams": {
          "_t": "{timestamp}",
          "_r": "{random}",
          "_fresh": "1"
        },
        "response": {
          "successPath": "!error",
          "dataPath": null,
          "fields": {
            "address": "email_addr",
            "token": "sid_token",
            "timestamp": "email_timestamp",
            "username": "email_user"
          }
        },
        "errorHandling": {
          "errorPath": "error",
          "errorMessagePath": "error"
        }
      },
      "checkEmail": {
        "method": "GET",
        "function": "check_email",
        "requiredParams": {
          "sid_token": "{auth.token}"
        },
        "optionalParams": {
          "seq": "{seq}"
        },
        "response": {
          "successPath": "!error",
          "dataPath": null,
          "fields": {}
        },
        "errorHandling": {
          "errorPath": "error",
          "errorMessagePath": "error"
        }
      },
      "fetchEmail": {
        "method": "GET",
        "function": "fetch_email",
        "requiredParams": {
          "sid_token": "{auth.token}",
          "email_id": "{email_id}"
        },
        "optionalParams": {},
        "response": {
          "successPath": "!error",
          "dataPath": null,
          "fields": {}
        },
        "errorHandling": {
          "errorPath": "error",
          "errorMessagePath": "error"
        }
      },
      "forgetMe": {
        "method": "GET",
        "function": "forget_me",
        "requiredParams": {
          "sid_token": "{auth.token}"
        },
        "optionalParams": {},
        "response": {
          "successPath": "!error",
          "dataPath": null,
          "fields": {}
        },
        "errorHandling": {
          "errorPath": "error",
          "errorMessagePath": "error"
        }
      },
      "setEmailUser": {
        "method": "POST",
        "function": "set_email_user",
        "requiredParams": {
          "sid_token": "{auth.token}",
          "email_user": "{emailUser}"
        },
        "optionalParams": {},
        "response": {
          "successPath": "!error",
          "dataPath": null,
          "fields": {
            "address": "email_addr",
            "timestamp": "email_timestamp"
          }
        },
        "errorHandling": {
          "errorPath": "error",
          "errorMessagePath": "error"
        }
      }
    },
    "emailFetching": {
      "type": "multi_step",
      "operation": null,
      "listOperation": "checkEmail",
      "listPath": "list",
      "listItemIdField": "mail_id",
      "detailOperation": "fetchEmail",
      "detailItemIdParam": "email_id",
      "detailResponseMapping": {
        "id": "mail_id",
        "from_name": "mail_from",
        "subject": "mail_subject",
        "body_html": "mail_body",
        "body_plain": "mail_excerpt",
        "timestamp_field": "mail_timestamp",
        "date_field": "mail_date",
        "fallback_timestamp_field": "ts"
      },
      "responseMapping": null,
      "sequenceTracking": {
        "enabled": true,
        "sequenceField": "lastSequence",
        "listSequenceField": "mail_id",
        "sequenceOperation": "max"
      }
    },
    "expiry": {
      "duration": 3600000,
      "renewable": true,
      "renewalMethod": "setEmailUser"
    },
    "customEmail": {
      "supported": true,
      "operation": "setEmailUser"
    },
    "multiInstance": {
      "enabled": false,
      "instances": []
    },
    "forceNewSession": {
      "enabled": true,
      "params": {
        "_t": "{timestamp}",
        "_r": "{random}",
        "_fresh": "1"
      },
      "headers": {
        "Cache-Control": "no-cache, no-store, must-revalidate",
        "Pragma": "no-cache",
        "Expires": "0",
        "X-Requested-With": "XMLHttpRequest"
      },
      "credentials": "omit",
      "cache": "no-cache"
    },
    "headers": {
      "default": {},
      "credentials": "include",
      "cache": "default"
    },
    "ui": {
      "canUnarchive": true,
      "supportsCustomEmail": true,
      "multiInstance": false,
      "supportsCustomInstance": false,
      "icon": "envelope",
      "color": "text-orange-500",
      "description": "Auto-renewing · Editable address"
    }
  },
