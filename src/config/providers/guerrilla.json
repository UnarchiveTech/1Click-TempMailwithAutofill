{
  "name": "Guerrilla Mail",
  "id": "guerrilla",
  "apiUrl": "https://api.guerrillamail.com/ajax.php",
  "auth": {
    "type": "query_parameter",
    "paramName": "sid_token",
    "description": "Session token returned by get_email_address, must be included in all subsequent requests"
  },
  "operations": {
    "get_email_address": {
      "method": "GET",
      "function": "get_email_address",
      "requiredParams": {
        "ip": "127.0.0.1",
        "agent": "1ClickExt"
      },
      "optionalParams": {
        "_t": "{timestamp}",
        "_r": "{random}",
        "_fresh": "1"
      },
      "response": {
        "successPath": "!error",
        "dataPath": null,
        "fields": {
          "address": "email_addr",
          "token": "sid_token",
          "timestamp": "email_timestamp",
          "username": "email_user"
        }
      },
      "errorHandling": {
        "errorPath": "error",
        "errorMessagePath": "error"
      }
    },
    "check_email": {
      "method": "GET",
      "function": "check_email",
      "requiredParams": {
        "sid_token": "{auth.token}"
      },
      "optionalParams": {
        "seq": "{seq}"
      },
      "response": {
        "successPath": "!error",
        "dataPath": null,
        "fields": {}
      },
      "errorHandling": {
        "errorPath": "error",
        "errorMessagePath": "error"
      }
    },
    "set_email_user": {
      "method": "POST",
      "function": "set_email_user",
      "requiredParams": {
        "sid_token": "{auth.token}",
        "email_user": "{emailUser}"
      },
      "optionalParams": {},
      "response": {
        "successPath": "!error",
        "dataPath": null,
        "fields": {
          "address": "email_addr",
          "timestamp": "email_timestamp"
        }
      },
      "errorHandling": {
        "errorPath": "error",
        "errorMessagePath": "error"
      }
    },
    "forget_me": {
      "method": "GET",
      "function": "forget_me",
      "requiredParams": {
        "sid_token": "{auth.token}"
      },
      "optionalParams": {},
      "response": {
        "successPath": "!error",
        "dataPath": null,
        "fields": {}
      },
      "errorHandling": {
        "errorPath": "error",
        "errorMessagePath": "error"
      }
    },
    "fetch_email": {
      "method": "GET",
      "function": "fetch_email",
      "requiredParams": {
        "sid_token": "{auth.token}",
        "email_id": "{email_id}"
      },
      "optionalParams": {},
      "response": {
        "successPath": "!error",
        "dataPath": null,
        "fields": {}
      },
      "errorHandling": {
        "errorPath": "error",
        "errorMessagePath": "error"
      }
    }
  },
  "expiry": {
    "duration": 3600000,
    "renewable": true,
    "renewalMethod": "get_new_sid_token_and_set_email_user"
  },
  "customEmail": {
    "supported": true,
    "operation": "set_email_user"
  },
  "headers": {
    "default": {},
    "credentials": "include",
    "cache": "default"
  },
  "forceNewSession": {
    "enabled": true,
    "params": {
      "_t": "{timestamp}",
      "_r": "{random}",
      "_fresh": "1"
    },
    "headers": {
      "Cache-Control": "no-cache, no-store, must-revalidate",
      "Pragma": "no-cache",
      "Expires": "0",
      "X-Requested-With": "XMLHttpRequest"
    },
    "credentials": "omit",
    "cache": "no-cache"
  }
}
