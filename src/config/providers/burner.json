{
  "name": "Burner.kiwi",
  "id": "burner",
  "apiUrl": "{instanceUrl}",
  "auth": {
    "type": "header",
    "paramName": "X-Burner-Key",
    "description": "Token returned by GET /inbox, must be included as header in all subsequent requests"
  },
  "operations": {
    "createInbox": {
      "method": "GET",
      "function": "/inbox",
      "requiredParams": {},
      "optionalParams": {},
      "response": {
        "successPath": "success",
        "dataPath": "result",
        "fields": {
          "address": "email.address",
          "id": "email.id",
          "token": "token",
          "createdAt": "email.created_at",
          "ttl": "email.ttl"
        }
      },
      "errorHandling": {
        "errorPath": "errors",
        "errorMessagePath": "errors.msg"
      }
    },
    "getInbox": {
      "method": "GET",
      "function": "/inbox/{inboxId}",
      "requiredParams": {},
      "optionalParams": {},
      "response": {
        "successPath": "success",
        "dataPath": "result",
        "fields": {
          "address": "address",
          "id": "id",
          "createdAt": "created_at",
          "ttl": "ttl"
        }
      },
      "errorHandling": {
        "errorPath": "errors",
        "errorMessagePath": "errors.msg"
      }
    },
    "fetchEmails": {
      "method": "GET",
      "function": "/inbox/{inboxId}/messages",
      "requiredParams": {},
      "optionalParams": {},
      "response": {
        "successPath": "success",
        "dataPath": "result",
        "fields": {}
      },
      "errorHandling": {
        "errorPath": "errors",
        "errorMessagePath": "errors.msg"
      }
    }
  },
  "expiry": {
    "duration": 86400000,
    "renewable": false,
    "renewalMethod": ""
  },
  "customEmail": {
    "supported": false,
    "operation": ""
  },
  "headers": {
    "default": {},
    "credentials": "include",
    "cache": "default"
  },
  "multiInstance": {
    "enabled": true,
    "randomSelectionDefault": true
  }
}
